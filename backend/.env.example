# ──────────────────────────────────────────────────────────────
# DnD Vault — backend env vars
# Copiar a .env y completar. NUNCA commitear .env.
# ──────────────────────────────────────────────────────────────

# DB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dnd_vault

# Auth
JWT_SECRET=cambiar-por-uno-seguro

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────────────────────
# Generación de imágenes con IA — Google Gemini 2.5 Flash Image
# Obtener clave en: https://aistudio.google.com/apikey
# Es OBLIGATORIA si querés usar la feature "Ilustrar sesión".
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
